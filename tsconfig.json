{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["chrome", "node"]
  },
  "include": ["src/**/*", "tests/**/*", "e2e/**/*", "wxt.config.ts", "playwright.config.ts"],
  "exclude": ["node_modules", ".output", ".wxt", "dist"]
}
